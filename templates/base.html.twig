<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}My Invoice{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 80 80%22><text y=%221em%22 font-size=%2270%22>🧾</text></svg>">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" referrerpolicy="no-referrer">
    {% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>
<header class="topbar">
    <div class="topbar-inner">
        <div class="brand-wrap">
            <a class="brand" href="{{ path('app_home') }}">My Invoice</a>
            <button class="version-chip" id="version-chip" type="button" title="Verificar atualizações" data-version-check-url="{{ path('app_system_version_check') }}">
                <span id="version-chip-current">v{{ app_version|default('dev') }}</span>
                <span class="version-update-badge" id="version-update-badge" hidden>NOVA</span>
            </button>
        </div>
        {% if app.user %}
            <nav class="nav">
                <a href="{{ path('app_invoice_index') }}">Invoices</a>
                <a href="{{ path('app_invoice_new') }}">Nova invoice</a>
                <a href="{{ path('app_company_index') }}">Empresas</a>
                <a href="{{ path('app_profile_edit') }}">Perfil</a>
                <a href="{{ path('app_logout') }}">Sair</a>
            </nav>
        {% endif %}
    </div>
</header>
<main class="container">
    {% for message in app.flashes('warning') %}
        <div class="flash flash-warning">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>
<div class="version-modal-backdrop" id="version-modal-backdrop" hidden>
    <div class="version-modal" role="dialog" aria-modal="true" aria-labelledby="version-modal-title">
        <div class="version-modal-head">
            <h3 id="version-modal-title">Atualização do sistema</h3>
            <button class="version-modal-close" id="version-modal-close" type="button" aria-label="Fechar">×</button>
        </div>
        <div class="version-modal-body">
            <p id="version-modal-summary">Verificando versões...</p>
            <div id="version-modal-update-content" hidden>
                <p><strong>Versão atual:</strong> <span id="version-current-value"></span></p>
                <p><strong>Nova versão disponível:</strong> <span id="version-latest-value"></span></p>
                <p><a id="version-release-link" href="#" target="_blank" rel="noopener">Ver detalhes da release</a></p>
                <p><strong>Como atualizar:</strong></p>
                <pre class="version-command" id="version-command-bash"></pre>
                <pre class="version-command" id="version-command-ps"></pre>
                <p class="muted">Se houver alterações locais não commitadas, adicione `--allow-dirty` ou `-AllowDirty`.</p>
            </div>
            <div id="version-modal-no-update-content" hidden>
                <p id="version-no-update-message">Você já está na versão mais recente.</p>
            </div>
        </div>
    </div>
</div>
</body>
</html>
