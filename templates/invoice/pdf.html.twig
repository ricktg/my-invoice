<!DOCTYPE html>
{% set invoice_locale = invoice.language|default('en') == 'pt-BR' ? 'pt_BR' : 'en' %}
<html lang="{{ invoice_locale == 'pt_BR' ? 'pt-BR' : 'en' }}">
<head>
    <meta charset="UTF-8">
    <title>Invoice {{ invoice.number }}</title>
    <style>
        @font-face {
            font-family: 'InvoiceSans';
            src: url('{{ fontFile }}') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        body {
            font-family: InvoiceSans, DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
            color: #222;
            margin: 28px;
        }
        h1 {
            margin: 0 0 10px;
            font-size: 28px;
            color: #2a5d77;
            font-weight: 500;
        }
        h2 {
            margin: 20px 0 8px;
            font-size: 18px;
            color: #2a5d77;
            font-weight: 500;
        }
        p {
            margin: 2px 0;
            line-height: 1.35;
        }
        .muted-line {
            border-top: 1px solid #d7d7d7;
            margin: 14px 0 12px;
        }
        .parties {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }
        .parties td {
            width: 50%;
            vertical-align: top;
            padding-right: 10px;
        }
        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
        }
        table.items th,
        table.items td {
            border: 1px solid #666;
            padding: 6px 8px;
            font-size: 11px;
        }
        table.items th { background: #f6f6f6; text-align: left; }
        .num { text-align: right; white-space: nowrap; }
        .total {
            margin-top: 16px;
        }
        .total .amount {
            font-size: 20px;
            font-weight: 700;
        }
        .terms {
            border-top: 1px solid #d7d7d7;
            margin-top: 18px;
            padding-top: 10px;
        }
    </style>
</head>
<body>
{% set periodStart = (invoice.referenceMonth ~ '-01')|date('F j, Y') %}
{% set periodEnd = (invoice.referenceMonth ~ '-01')|date_modify('+1 month -1 day')|date('F j, Y') %}

<h1>INVOICE</h1>
<p><strong>{{ 'invoice.label.number'|trans({}, 'messages', invoice_locale) }}:</strong> {{ invoice.number }}</p>
<p><strong>{{ 'invoice.label.date'|trans({}, 'messages', invoice_locale) }}:</strong> {{ invoice.issueDate|date('F j, Y') }}</p>
<p><strong>{{ 'invoice.label.service_period'|trans({}, 'messages', invoice_locale) }}:</strong> {{ periodStart }} - {{ periodEnd }}</p>

<div class="muted-line"></div>

<table class="parties">
    <tr>
        <td>
            <h2>{{ 'invoice.section.from'|trans({}, 'messages', invoice_locale) }}</h2>
            <p><strong>{{ invoice.issuerCompany.name }}</strong></p>
            {% if invoice.issuerCompany.address %}
                <p>{{ invoice.issuerCompany.address|nl2br }}</p>
            {% endif %}
            {% if invoice.issuerCompany.taxId %}
                <p>Tax ID: {{ invoice.issuerCompany.taxId }}</p>
            {% endif %}
            {% if invoice.issuerCompany.email %}
                <p>Email: {{ invoice.issuerCompany.email }}</p>
            {% endif %}
        </td>
        <td>
            <h2>{{ 'invoice.section.bill_to'|trans({}, 'messages', invoice_locale) }}</h2>
            <p><strong>{{ invoice.recipientCompany.name }}</strong></p>
            <p>{{ 'invoice.attn_finance'|trans({}, 'messages', invoice_locale) }}</p>
            {% if invoice.recipientCompany.address %}
                <p>{{ invoice.recipientCompany.address|nl2br }}</p>
            {% endif %}
            {% if invoice.recipientCompany.taxId %}
                <p>Tax ID: {{ invoice.recipientCompany.taxId }}</p>
            {% endif %}
            {% if invoice.recipientCompany.email %}
                <p>Email: {{ invoice.recipientCompany.email }}</p>
            {% endif %}
        </td>
    </tr>
</table>

<h2>{{ 'invoice.section.services'|trans({}, 'messages', invoice_locale) }}</h2>
<table class="items">
    <thead>
    <tr>
        <th>{{ 'invoice.table.type'|trans({}, 'messages', invoice_locale) }}</th>
        <th>{{ 'invoice.table.description'|trans({}, 'messages', invoice_locale) }}</th>
        <th class="num">{{ 'invoice.table.quantity'|trans({}, 'messages', invoice_locale) }}</th>
        <th class="num">{{ 'invoice.table.rate'|trans({}, 'messages', invoice_locale) }} ({{ invoice.currency }})</th>
        <th class="num">{{ 'invoice.table.amount'|trans({}, 'messages', invoice_locale) }} ({{ invoice.currency }})</th>
    </tr>
    </thead>
    <tbody>
    {% for item in invoice.items %}
        <tr>
            <td>{{ ('invoice.billing_type.' ~ item.billingType)|trans({}, 'messages', invoice_locale) }}</td>
            <td>{{ item.description }}</td>
            <td class="num">{{ item.displayQuantity }}</td>
            <td class="num">{{ item.unitPrice|number_format(2, '.', ',') }}</td>
            <td class="num">{{ item.totalAmount|number_format(2, '.', ',') }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="total">
    <h2>{{ 'invoice.section.total_due'|trans({}, 'messages', invoice_locale) }}</h2>
    <p class="amount">{{ invoice.currency }} {{ invoice.totalAmount|number_format(2, '.', ',') }}</p>
</div>

<div class="terms">
    <p><strong>{{ 'invoice.section.payment_terms'|trans({}, 'messages', invoice_locale) }}</strong></p>
    <p>{{ 'invoice.payment_terms_10_days'|trans({}, 'messages', invoice_locale) }}</p>
    <p>{{ 'invoice.label.due_date'|trans({}, 'messages', invoice_locale) }}: {{ invoice.dueDate ? invoice.dueDate|date('F j, Y') : '-' }}</p>
</div>

{% if invoice.notes %}
    <div class="terms">
        <p><strong>{{ 'invoice.label.notes'|trans({}, 'messages', invoice_locale) }}</strong></p>
        <p>{{ invoice.notes|nl2br }}</p>
    </div>
{% endif %}
</body>
</html>
